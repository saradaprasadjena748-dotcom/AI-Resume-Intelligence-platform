# Copy this file to .env and fill in ONE provider's key.
# The app works without any key (template-based fallback) but generated
# resume text and the career-coach chatbot will be far better with a real LLM.

# Which provider to use: openai | gemini | anthropic | none
AI_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
